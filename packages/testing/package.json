{
  "name": "@amqp-contract/testing",
  "version": "2.4.1",
  "description": "Testing utilities for AMQP contracts with testcontainers",
  "keywords": [
    "amqp",
    "contract",
    "nodejs",
    "rabbitmq",
    "testcontainers",
    "testing",
    "type-safe",
    "typescript",
    "vitest"
  ],
  "homepage": "https://github.com/btravstack/amqp-contract#readme",
  "bugs": {
    "url": "https://github.com/btravstack/amqp-contract/issues"
  },
  "license": "MIT",
  "author": "Benoit TRAVERS <benoit.travers.fr@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/btravstack/amqp-contract.git",
    "directory": "packages/testing"
  },
  "files": [
    "dist",
    "docs"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./global-setup": {
      "types": "./dist/global-setup.d.mts",
      "import": "./dist/global-setup.mjs"
    },
    "./extension": {
      "types": "./dist/extension.d.mts",
      "import": "./dist/extension.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts src/global-setup.ts src/extension.ts --format esm --dts --clean",
    "build:docs": "typedoc",
    "typecheck": "tsc --noEmit",
    "check:package": "publint --strict && attw --pack . --profile esm-only"
  },
  "dependencies": {
    "amqplib": "catalog:",
    "testcontainers": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@btravstack/tsconfig": "catalog:",
    "@btravstack/typedoc": "catalog:",
    "@types/node": "catalog:",
    "publint": "catalog:",
    "tsdown": "catalog:",
    "typedoc": "catalog:",
    "typedoc-plugin-markdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "vitest": "^4"
  },
  "engines": {
    "node": ">=22.19"
  }
}
