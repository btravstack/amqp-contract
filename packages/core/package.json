{
  "name": "@amqp-contract/core",
  "version": "1.0.0",
  "description": "Core utilities for AMQP setup and management in amqp-contract",
  "keywords": [
    "amqp",
    "contract",
    "core",
    "message-broker",
    "message-queue",
    "messaging",
    "metrics",
    "nodejs",
    "opentelemetry",
    "rabbitmq",
    "tracing",
    "type-safe",
    "typescript"
  ],
  "homepage": "https://github.com/btravstack/amqp-contract#readme",
  "bugs": {
    "url": "https://github.com/btravstack/amqp-contract/issues"
  },
  "license": "MIT",
  "author": "Benoit TRAVERS <benoit.travers.fr@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/btravstack/amqp-contract.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "docs"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs,esm --dts --clean",
    "build:docs": "typedoc",
    "dev": "tsdown src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@amqp-contract/contract": "workspace:*",
    "amqp-connection-manager": "catalog:",
    "amqplib": "catalog:",
    "unthrown": "catalog:"
  },
  "devDependencies": {
    "@amqp-contract/testing": "workspace:*",
    "@amqp-contract/tsconfig": "workspace:*",
    "@amqp-contract/typedoc": "workspace:*",
    "@opentelemetry/api": "catalog:",
    "@types/node": "catalog:",
    "@unthrown/vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsdown": "catalog:",
    "typedoc": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.19"
  }
}
